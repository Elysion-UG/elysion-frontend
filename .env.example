# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# Backend API URL (client-side)
# Leave empty for relative paths (recommended with subdomains — keeps requests same-origin).
# Only set for direct backend access without Next.js proxy:
#   http://localhost:8080  or  https://marketplace-backend-1-1w30.onrender.com
NEXT_PUBLIC_API_URL=

# Seller portal domain
# Dev:  seller.localhost:3000
# Prod: seller.yourdomain.com

# Server-side: middleware redirects /seller-dashboard on main domain to seller domain
SELLER_DOMAIN=seller.localhost:3000

# Client-side: SellerLogin redirects directly to seller domain after login
NEXT_PUBLIC_SELLER_DOMAIN=seller.localhost:3000

# Admin portal domain
# Dev:  admin.localhost:3000
# Prod: admin.yourdomain.com

# Server-side: middleware redirects /admin on main domain to admin domain
ADMIN_DOMAIN=admin.localhost:3000

# Client-side: AdminLogin redirects directly to admin domain after login
NEXT_PUBLIC_ADMIN_DOMAIN=admin.localhost:3000

# Client-side: buyer (main shop) domain — used to redirect back from seller/admin portal
NEXT_PUBLIC_BUYER_DOMAIN=localhost:3000

# Server-side: middleware redirects non-portal paths back to buyer domain
BUYER_DOMAIN=localhost:3000
