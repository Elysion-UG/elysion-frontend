# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# Backend API URL
# Development: http://localhost:8080
# Production:  https://marketplace-backend-1-1w30.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# Seller portal domain (server-side only — no NEXT_PUBLIC_ prefix)
# Dev:  seller.localhost:3000
# Prod: seller.yourdomain.com
# When set, /seller-dashboard on the main domain redirects to this domain.
SELLER_DOMAIN=seller.localhost:3000
